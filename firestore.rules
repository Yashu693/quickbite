rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin Global Read/Write Access
    match /{document=**} {
      // Allows any user with a custom 'admin' token OR the specific admin emails to do anything
      allow read, write: if request.auth != null && (
        request.auth.token.admin == true || 
        request.auth.token.email == 'shahyassh1804@gmail.com' || 
        request.auth.token.email == 'shahyash1804@gmail.com'
      );
    }

    // Default Deny All (Strict security baseline) for non-admins
    // NOTE: This does not override explicit allows below
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // REVIEWS COLLECTION
    // ---------------------------------------------------------
    match /reviews/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ---------------------------------------------------------
    // FEEDBACK COLLECTION
    // ---------------------------------------------------------
    match /feedback/{docId} {
      allow create: if request.auth != null && 
                    request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && 
                    resource.data.uid == request.auth.uid;              
      allow read, delete: if false; // Reserved for admin
    }

    // ---------------------------------------------------------
    // USERS COLLECTION AND SUBCOLLECTIONS
    // ---------------------------------------------------------
    match /users/{userId} {
      
      // Read & Delete profile
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      
      // Profile Creation & Updates
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // CART SUBCOLLECTION: users/{userId}/cart/{document}
      match /cart/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ORDERS SUBCOLLECTION: users/{userId}/orders/{orderId}
      match /orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // ADDRESSES SUBCOLLECTION: users/{userId}/addresses/{docId}
      match /addresses/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // SETTINGS SUBCOLLECTION: users/{userId}/settings/{docId}
      match /settings/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Global orders collection (if used independently from users subcollection)
    match /orders/{orderId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
    }
  }
}
